# MangaVerse — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git — it's already in .gitignore


# MongoDB
# Local:      mongodb://localhost:27017/mangaverse
# Docker:     mongodb://mongo:27017/mangaverse
# Production: Get connection string from MongoDB Atlas
#             https://cloud.mongodb.com
MONGODB_URI=mongodb://localhost:27017/mangaverse

# Session
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=

# Google OAuth
# Get credentials: https://console.cloud.google.com
# APIs & Services → Credentials → Create OAuth 2.0 Client
# Add redirect URIs in Google Console:
#   http://localhost:5000/api/auth/google/callback         (dev)
#   https://staging.yourdomain.com/api/auth/google/callback  (staging)
#   https://api.yourdomain.com/api/auth/google/callback    (prod)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# URLs
# Production: https://api.yourdomain.com / https://yourdomain.com
SERVER_URL=http://localhost:5000
CLIENT_URL=http://localhost:3000

# Environment — development | staging | production
NODE_ENV=development
PORT=5000

# Email — Resend
# Get API key: https://resend.com → API Keys
# Dev:  EMAIL_FROM=onboarding@resend.dev (sends only to your Resend account email)
# Prod: EMAIL_FROM=MangaVerse <noreply@yourdomain.com>
# Verify domain first: Resend Dashboard → Domains → Add Domain
RESEND_API_KEY=
EMAIL_FROM=onboarding@resend.dev

# VAPID — Web Push Notifications
# Generate: npx web-push generate-vapid-keys
# Never reuse prod keys in dev
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@yourdomain.com